{
  "words": [
    {"pIndex": 0, "lIndex": 0, "start": 7.32, "end": 8.54, "text": "Eräkoira,"},
    {"pIndex": 0, "lIndex": 0, "start": 8.56, "end": 9.48, "text": "freesi ja kliini"},
    {"pIndex": 0, "lIndex": 1, "start": 9.48, "end": 10.58, "text": "Todellisuudessa"},
    {"pIndex": 0, "lIndex": 1, "start": 10.58, "end": 11.54, "text": "loota on kiinni"},
    {"pIndex": 0, "lIndex": 2, "start": 11.54, "end": 12.50, "text": "Thono Slono"},
    {"pIndex": 0, "lIndex": 2, "start": 12.54, "end": 13.50, "text": "lähiörotta"},
    {"pIndex": 0, "lIndex": 3, "start": 13.50, "end": 14.18, "text": "Turn it up,"},
    {"pIndex": 0, "lIndex": 3, "start": 14.18, "end": 14.68, "text": "turn it up"},
    {"pIndex": 0, "lIndex": 4, "start": 14.68, "end": 15.08, "text": "Tää on"},
    {"pIndex": 0, "lIndex": 4, "start": 15.08, "end": 15.86, "text": "täyttä totta"},

    {"pIndex": 1, "lIndex": 5, "start": 15.86, "end": 16.72, "text": "Nyt juomaan"},
    {"pIndex": 1, "lIndex": 5, "start": 16.72, "end": 16.90, "text": "nakit"},
    {"pIndex": 1, "lIndex": 6, "start": 17.08, "end": 17.58, "text": "Otetaan"},
    {"pIndex": 1, "lIndex": 6, "start": 17.58, "end": 18.14, "text": "samantien"},
    {"pIndex": 1, "lIndex": 6, "start": 18.14, "end": 18.50, "text": "nakit nakit"},
    {"pIndex": 1, "lIndex": 7, "start": 18.50, "end": 19.62, "text": "Kolmet"},
    {"pIndex": 1, "lIndex": 7, "start": 19.62, "end": 20.06, "text": "nakit"},
    {"pIndex": 1, "lIndex": 8, "start": 20.06, "end": 20.76, "text": "Bongi,"},
    {"pIndex": 1, "lIndex": 8, "start": 20.76, "end": 21.96, "text": "reggaebongi"},
    {"pIndex": 1, "lIndex": 8, "start": 21.96, "end": 22.44, "text": "bongi"},
    {"pIndex": 1, "lIndex": 9, "start": 22.44, "end": 23.12, "text": "Koo,"},
    {"pIndex": 1, "lIndex": 9, "start": 23.12, "end": 24.20, "text": "kolahtaa bongi"},

    {"pIndex": 2, "lIndex": 10, "start": 24.20, "end": 24.72, "text": "Juomaan"},
    {"pIndex": 2, "lIndex": 10, "start": 24.72, "end": 24.90, "text": "nakit"},
    {"pIndex": 2, "lIndex": 11, "start": 25.14, "end": 25.66, "text": "Otetaan"},
    {"pIndex": 2, "lIndex": 11, "start": 25.66, "end": 26.22, "text": "samantien"},
    {"pIndex": 2, "lIndex": 11, "start": 26.22, "end": 26.56, "text": "nakit nakit"},
    {"pIndex": 2, "lIndex": 12, "start": 26.56, "end": 27.68, "text": "Kolmet"},
    {"pIndex": 2, "lIndex": 12, "start": 27.68, "end": 28.14, "text": "nakit,"},
    {"pIndex": 2, "lIndex": 13, "start": 28.16, "end": 28.78, "text": "Bongi,"},
    {"pIndex": 2, "lIndex": 13, "start": 28.78, "end": 29.98, "text": "reggaebongi"},
    {"pIndex": 2, "lIndex": 13, "start": 30.00, "end": 30.48, "text": "bongi"},
    {"pIndex": 2, "lIndex": 14, "start": 30.48, "end": 31.00, "text": "Koo,"},
    {"pIndex": 2, "lIndex": 14, "start": 31.00, "end": 32.26, "text": "kolahtaa bongi"},

    {"pIndex": 3, "lIndex": 15, "start": 32.26, "end": 32.76, "text": "Savuista"},
    {"pIndex": 3, "lIndex": 15, "start": 32.76, "end": 33.30, "text": "silmät"},
    {"pIndex": 3, "lIndex": 15, "start": 33.30, "end": 33.78, "text": "sakeena"},
    {"pIndex": 3, "lIndex": 16, "start": 33.78, "end": 34.74, "text": "On täällä monni"},
    {"pIndex": 3, "lIndex": 16, "start": 34.74, "end": 35.68, "text": "kuin moni karkeella"},
    {"pIndex": 3, "lIndex": 17, "start": 35.68, "end": 36.90, "text": "Joku on valkoinen"},
    {"pIndex": 3, "lIndex": 17, "start": 36.90, "end": 37.84, "text": "toinen ku vainaa"},
    {"pIndex": 3, "lIndex": 18, "start": 37.84, "end": 38.84, "text": "Ukot separoi"},
    {"pIndex": 3, "lIndex": 18, "start": 38.84, "end": 40.32, "text": "kädet taskuja kaivaa"},
    {"pIndex": 3, "lIndex": 19, "start": 40.32, "end": 41.34, "text": "Kiikkuu ja vaappuu"},
    {"pIndex": 3, "lIndex": 19, "start": 41.48, "end": 42.30, "text": "huppelis taatuu"},
    {"pIndex": 3, "lIndex": 20, "start": 42.30, "end": 43.36, "text": "Muistiki taantuu"},
    {"pIndex": 3, "lIndex": 20, "start": 43.46, "end": 44.34, "text": "tais olla laatuu"},
    {"pIndex": 3, "lIndex": 21, "start": 44.34, "end": 45.88, "text": "Ja loota oon kii,"},
    {"pIndex": 3, "lIndex": 21, "start": 45.88, "end": 46.86, "text": "kui monta katset"},
    {"pIndex": 3, "lIndex": 21, "start": 46.86, "end": 47.76, "text": "katossa on me"},
    {"pIndex": 3, "lIndex": 22, "start": 47.76, "end": 49.96, "text": "Taustalla bostaa"},
    {"pIndex": 3, "lIndex": 23, "start": 50.06, "end": 51.40, "text": "Pimeissä nurkista"},
    {"pIndex": 3, "lIndex": 23, "start": 51.40, "end": 52.50, "text": "fiilistä nostaa"},
    {"pIndex": 3, "lIndex": 24, "start": 52.50, "end": 54.00, "text": "Tanssila flossaa"},
    {"pIndex": 3, "lIndex": 25, "start": 54.12, "end": 55.32, "text": "Kato, jalkaduunii"},
    {"pIndex": 3, "lIndex": 25, "start": 55.32, "end": 56.68, "text": "ei hävitä koskaan"},
    {"pIndex": 3, "lIndex": 26, "start": 56.82, "end": 57.98, "text": "Huominen kostaa."},
    {"pIndex": 3, "lIndex": 26, "start": 57.98, "end": 59.24, "text": "Se ei paina tänään"},
    {"pIndex": 3, "lIndex": 27, "start": 59.28, "end": 60.48, "text": "Pari kaipiroskaa"},
    {"pIndex": 3, "lIndex": 27, "start": 60.80, "end": 62.02, "text": "antaa ja ottaa"},
    {"pIndex": 3, "lIndex": 28, "start": 62.02, "end": 63.48, "text": "Pannaa paikasta sisää,"},
    {"pIndex": 3, "lIndex": 28, "start": 63.56, "end": 64.56, "text": "tost vaa"},

    {"pIndex": 4, "lIndex": 29, "start": 64.56, "end": 65.52, "text": "Mitä ideaa"},
    {"pIndex": 4, "lIndex": 29, "start": 65.52, "end": 66.54, "text": "nartuille ja piskeille"},
    {"pIndex": 4, "lIndex": 30, "start": 66.60, "end": 67.32, "text": "Pysäyttää meitä"},
    {"pIndex": 4, "lIndex": 30, "start": 67.32, "end": 68.56, "text": "Kun me rynnitään tiskeille"},
    {"pIndex": 4, "lIndex": 31, "start": 68.56, "end": 69.32, "text": "Hämyiset rahat"},
    {"pIndex": 4, "lIndex": 31, "start": 69.32, "end": 70.50, "text": "halpa sikari"},
    {"pIndex": 4, "lIndex": 32, "start": 70.54, "end": 71.48, "text": "Ei jääny tyhjäksi"},
    {"pIndex": 4, "lIndex": 32, "start": 71.48, "end": 72.52, "text": "lasit eikä pikarit"},
    {"pIndex": 4, "lIndex": 33, "start": 72.60, "end": 73.46, "text": "Patukat palaa"},
    {"pIndex": 4, "lIndex": 33, "start": 73.46, "end": 74.60, "text": "täällä takarivissä"},
    {"pIndex": 4, "lIndex": 34, "start": 74.60, "end": 75.32, "text": "Ei oo multa pois"},
    {"pIndex": 4, "lIndex": 34, "start": 75.32, "end": 76.50, "text": "Jos sä et oo hyvissä"},
    {"pIndex": 4, "lIndex": 35, "start": 76.60, "end": 77.46, "text": "Basson tahtii"},
    {"pIndex": 4, "lIndex": 35, "start": 77.46, "end": 77.90, "text": "just nii"},
    {"pIndex": 4, "lIndex": 36, "start": 78.28, "end": 79.12, "text": "Samaan tahtii"},
    {"pIndex": 4, "lIndex": 36, "start": 79.12, "end": 80.50, "text": "loota menee kii"},
    {"pIndex": 4, "lIndex": 37, "start": 80.50, "end": 81.34, "text": "Kallion ylin,"},
    {"pIndex": 4, "lIndex": 37, "start": 81.56, "end": 82.62, "text": "kives ku sementti"},
    {"pIndex": 4, "lIndex": 38, "start": 82.62, "end": 83.30, "text": "Jokainen nii"},
    {"pIndex": 4, "lIndex": 38, "start": 83.58, "end": 84.66, "text": "iso presidentti"},
    {"pIndex": 4, "lIndex": 39, "start": 84.66, "end": 85.42, "text": "Tanssimaan"},
    {"pIndex": 4, "lIndex": 39, "start": 85.56, "end": 86.58, "text": "ei Eräkoira rupee"},
    {"pIndex": 4, "lIndex": 40, "start": 86.58, "end": 87.66, "text": "Vaan aikoo pitää"},
    {"pIndex": 4, "lIndex": 40, "start": 87.70, "end": 88.68, "text": "blondeista tukea"},
    {"pIndex": 4, "lIndex": 41, "start": 89.86, "end": 90.38, "text": "Olot on"},
    {"pIndex": 4, "lIndex": 41, "start": 90.38, "end": 90.72, "text": "totta kai tukevat"},
    {"pIndex": 4, "lIndex": 42, "start": 90.78, "end": 91.68, "text": "Katso silmiin"},
    {"pIndex": 4, "lIndex": 42, "start": 91.68, "end": 92.72, "text": "rudeboy stugea"},
    {"pIndex": 4, "lIndex": 43, "start": 92.76, "end": 93.58, "text": "Eräkoira on"},
    {"pIndex": 4, "lIndex": 43, "start": 93.58, "end": 94.58, "text": "lähiösuperstara"},
    {"pIndex": 4, "lIndex": 44, "start": 94.72, "end": 95.68, "text": "Silmät ristis"},
    {"pIndex": 4, "lIndex": 44, "start": 95.68, "end": 96.72, "text": "lasien takan"},

    {"pIndex": 5, "lIndex": 45, "start": 96.72, "end": 97.36, "text": "Juodaan"},
    {"pIndex": 5, "lIndex": 45, "start": 97.36, "end": 97.70, "text": "shotit"},
    {"pIndex": 5, "lIndex": 46, "start": 97.70, "end": 98.32, "text": "Otetaan"},
    {"pIndex": 5, "lIndex": 46, "start": 98.32, "end": 98.82, "text": "samantien"},
    {"pIndex": 5, "lIndex": 46, "start": 98.82, "end": 99.64, "text": "shotit shotit"},
    {"pIndex": 5, "lIndex": 47, "start": 99.64, "end": 100.40, "text": "Kolmet"},
    {"pIndex": 5, "lIndex": 47, "start": 100.40, "end": 100.76, "text": "shotit"},
    {"pIndex": 5, "lIndex": 48, "start": 100.76, "end": 101.48, "text": "Blondi"},
    {"pIndex": 5, "lIndex": 48, "start": 101.48, "end": 102.64, "text": "Reggaeblondit"},
    {"pIndex": 5, "lIndex": 48, "start": 102.64, "end": 103.20, "text": "blondit"},
    {"pIndex": 5, "lIndex": 49, "start": 103.20, "end": 103.40, "text": "Äää!"},
    {"pIndex": 5, "lIndex": 49, "start": 103.40, "end": 104.90, "text": "Kolahtaa blondi"},

    {"pIndex": 6, "lIndex": 50, "start": 104.90, "end": 105.46, "text": "Juodaan"},
    {"pIndex": 6, "lIndex": 50, "start": 105.46, "end": 105.84, "text": "shotit"},
    {"pIndex": 6, "lIndex": 51, "start": 105.84, "end": 106.32, "text": "Otetaan"},
    {"pIndex": 6, "lIndex": 51, "start": 106.32, "end": 106.88, "text": "samantien"},
    {"pIndex": 6, "lIndex": 51, "start": 106.88, "end": 107.60, "text": "shotit shotit"},
    {"pIndex": 6, "lIndex": 52, "start": 107.60, "end": 108.38, "text": "Kolmet"},
    {"pIndex": 6, "lIndex": 52, "start": 108.38, "end": 108.82, "text": "shotit"},
    {"pIndex": 6, "lIndex": 53, "start": 108.82, "end": 109.50, "text": "Blondi"},
    {"pIndex": 6, "lIndex": 53, "start": 109.50, "end": 110.72, "text": "Reggaeblondit"},
    {"pIndex": 6, "lIndex": 53, "start": 110.72, "end": 111.24, "text": "blondit"},
    {"pIndex": 6, "lIndex": 54, "start": 111.24, "end": 111.80, "text": "Äää!"},
    {"pIndex": 6, "lIndex": 54, "start": 111.80, "end": 112.78, "text": "Kolahtaa blondi"},

    {"pIndex": 7, "lIndex": 55, "start": 112.78, "end": 113.52, "text": "Se on ThonoSlono"},
    {"pIndex": 7, "lIndex": 55, "start": 113.56, "end": 114.46, "text": "joka tulee tiputtaa"},
    {"pIndex": 7, "lIndex": 56, "start": 114.46, "end": 115.48, "text": "Ei voi tätä heittaa,"},
    {"pIndex": 7, "lIndex": 56, "start": 115.50, "end": 116.48, "text": "basso alkaa liikuttaa"},
    {"pIndex": 7, "lIndex": 57, "start": 116.48, "end": 116.90, "text": "Sillon on"},
    {"pIndex": 7, "lIndex": 57, "start": 116.90, "end": 117.48, "text": "pakko"},
    {"pIndex": 7, "lIndex": 57, "start": 117.48, "end": 118.56, "text": "vaan antautuu"},
    {"pIndex": 7, "lIndex": 58, "start": 118.56, "end": 119.58, "text": "Projekti Loota Kii"},
    {"pIndex": 7, "lIndex": 58, "start": 119.60, "end": 120.78, "text": "Saundi kantautuu"},
    {"pIndex": 7, "lIndex": 59, "start": 120.78, "end": 121.88, "text": "Yli stadikatornin, Hietsun"},
    {"pIndex": 7, "lIndex": 59, "start": 122.22, "end": 122.68, "text": "rannalle"},
    {"pIndex": 7, "lIndex": 60, "start": 123.16, "end": 124.02, "text": "Tytöt bikineissä,"},
    {"pIndex": 7, "lIndex": 60, "start": 124.08, "end": 125.22, "text": "sydän on pulmanne"},
    {"pIndex": 7, "lIndex": 61, "start": 125.22, "end": 126.60, "text": "Huikkaa ja dullaa,"},
    {"pIndex": 7, "lIndex": 61, "start": 126.64, "end": 127.56, "text": "kunnolla kurlaa"},
    {"pIndex": 7, "lIndex": 62, "start": 127.56, "end": 128.08, "text": "Mennää"},
    {"pIndex": 7, "lIndex": 62, "start": 128.08, "end": 128.68, "text": "päätyyn"},
    {"pIndex": 7, "lIndex": 62, "start": 128.70, "end": 129.12, "text": "buljaan"},

    {"pIndex": 8, "lIndex": 63, "start": 129.12, "end": 130.54, "text": "Anna ne massit!"},
    {"pIndex": 8, "lIndex": 63, "start": 130.54, "end": 132.12, "text": "Ei nabise viuhalle,"},
    {"pIndex": 8, "lIndex": 63, "start": 132.18, "end": 132.98, "text": "hoidetaan hatsit"},
    {"pIndex": 8, "lIndex": 64, "start": 133.14, "end": 134.56, "text": "Vuosien tatsi."},
    {"pIndex": 8, "lIndex": 64, "start": 134.56, "end": 136.10, "text": "Valmiina asemis,"},
    {"pIndex": 8, "lIndex": 64, "start": 136.14, "end": 137.06, "text": "saapumas lasti"},
    {"pIndex": 8, "lIndex": 65, "start": 137.06, "end": 138.68, "text": "Täällä on tanssit."},
    {"pIndex": 8, "lIndex": 65, "start": 138.68, "end": 140.16, "text": "On ihmisringissä"},
    {"pIndex": 8, "lIndex": 65, "start": 140.24, "end": 141.22, "text": "käynnissä matsi"},
    {"pIndex": 8, "lIndex": 66, "start": 141.22, "end": 142.70, "text": "Kestääkö kantti?"},
    {"pIndex": 8, "lIndex": 66, "start": 142.72, "end": 144.24, "text": "Kaikki überviboissa,"},
    {"pIndex": 8, "lIndex": 66, "start": 144.28, "end": 145.08, "text": "melkein transsis"},

    {"pIndex": 9, "lIndex": 67, "start": 145.08, "end": 145.76, "text": "Nyt juomaan"},
    {"pIndex": 9, "lIndex": 67, "start": 145.76, "end": 146.06, "text": "nakit"},
    {"pIndex": 9, "lIndex": 68, "start": 146.12, "end": 146.68, "text": "Otetaan"},
    {"pIndex": 9, "lIndex": 68, "start": 146.68, "end": 147.20, "text": "samantien"},
    {"pIndex": 9, "lIndex": 68, "start": 147.20, "end": 147.88, "text": "nakit nakit"},
    {"pIndex": 9, "lIndex": 69, "start": 147.88, "end": 148.64, "text": "Kolmet"},
    {"pIndex": 9, "lIndex": 69, "start": 148.64, "end": 149.12, "text": "nakit"},
    {"pIndex": 9, "lIndex": 70, "start": 149.16, "end": 149.76, "text": "Bongi,"},
    {"pIndex": 9, "lIndex": 70, "start": 149.76, "end": 151.04, "text": "Reggaebongi"},
    {"pIndex": 9, "lIndex": 70, "start": 151.06, "end": 151.52, "text": "bongi"},
    {"pIndex": 9, "lIndex": 71, "start": 152.32, "end": 152.80, "text": "Koo,"},
    {"pIndex": 9, "lIndex": 71, "start": 152.80, "end": 153.30, "text": "kolahtaa bongi"},

    {"pIndex": 10, "lIndex": 72, "start": 153.30, "end": 153.84, "text": "Juodaan"},
    {"pIndex": 10, "lIndex": 72, "start": 153.84, "end": 154.20, "text": "shotit"},
    {"pIndex": 10, "lIndex": 73, "start": 154.20, "end": 154.76, "text": "Otetaan"},
    {"pIndex": 10, "lIndex": 73, "start": 154.76, "end": 155.28, "text": "samantien"},
    {"pIndex": 10, "lIndex": 73, "start": 155.28, "end": 156.06, "text": "shotit shotit"},
    {"pIndex": 10, "lIndex": 74, "start": 156.06, "end": 156.88, "text": "Kolmet"},
    {"pIndex": 10, "lIndex": 74, "start": 156.88, "end": 157.22, "text": "shotit"},
    {"pIndex": 10, "lIndex": 75, "start": 157.24, "end": 157.80, "text": "Blondi"},
